{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$(git rev-parse --show-toplevel)/.agents/skills/review-learnings/scripts/record.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$(git rev-parse --show-toplevel)/.agents/skills/review-learnings/scripts/backfill.sh\" --cli codex",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
